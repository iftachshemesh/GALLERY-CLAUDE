<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>עריכת טקסט תערוכות | ניהול</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .editor-toolbar { display:flex; flex-wrap:wrap; gap:0.3rem; padding:0.6rem; background:var(--cream); border:1px solid var(--border); border-bottom:none; border-radius:4px 4px 0 0; align-items:center; }
    .editor-toolbar button { padding:0.3rem 0.6rem; background:var(--white); border:1px solid var(--border); border-radius:3px; cursor:pointer; font-size:0.85rem; transition:all 0.15s; white-space:nowrap; }
    .editor-toolbar button:hover { background:var(--gold-light); }
    .editor-toolbar select { padding:0.3rem 0.5rem; border:1px solid var(--border); border-radius:3px; background:var(--white); font-size:0.82rem; cursor:pointer; color:var(--dark); }
    .editor-toolbar .sep { width:1px; height:22px; background:var(--border); margin:0 0.2rem; }
    .editor-area { min-height:300px; padding:1.2rem; border:1px solid var(--border); border-radius:0 0 4px 4px; outline:none; background:var(--white); font-family:inherit; font-size:1rem; line-height:1.9; }
  </style>
</head>
<body dir="rtl">
<div class="admin-layout">
  <%- include('_sidebar') %>
  <main class="admin-main">
    <h1 class="admin-title">עריכת טקסט תערוכות</h1>
    <p style="color:var(--muted); margin-bottom:1.5rem; font-size:0.9rem;">טקסט זה יופיע מעל גריד התמונות בדף "תערוכות וכתבות".</p>

    <form method="POST" action="/admin/exhibitions-text" id="exForm">

      <!-- עברית -->
      <div class="admin-card">
        <h3 style="margin-bottom:1rem; color:var(--charcoal); font-size:1.1rem;">תוכן בעברית</h3>
        <div class="editor-toolbar">
          <select onchange="fmtBlock('he',this.value);this.value=''">
            <option value="">כותרת...</option>
            <option value="h2">H2</option>
            <option value="h3">H3</option>
            <option value="p">פסקה</option>
          </select>
          <div class="sep"></div>
          <button type="button" onclick="fmt('he','bold')"><b>B</b></button>
          <button type="button" onclick="fmt('he','italic')"><i>I</i></button>
          <button type="button" onclick="fmt('he','underline')"><u>U</u></button>
          <div class="sep"></div>
          <button type="button" onclick="fmt('he','insertUnorderedList')">• רשימה</button>
          <button type="button" onclick="fmt('he','insertOrderedList')">1. רשימה</button>
          <div class="sep"></div>
          <button type="button" onclick="fmt('he','removeFormat')">✕ נקה</button>
        </div>
        <div class="editor-area" id="editor-he" contenteditable="true" dir="rtl"><%- exContent ? exContent.content_he : '' %></div>
        <input type="hidden" name="content_he" id="content_he">
      </div>

      <!-- אנגלית -->
      <div class="admin-card">
        <h3 style="margin-bottom:1rem; color:var(--charcoal); font-size:1.1rem;">Content in English</h3>
        <div class="editor-toolbar">
          <select onchange="fmtBlock('en',this.value);this.value=''">
            <option value="">Heading...</option>
            <option value="h2">H2</option>
            <option value="h3">H3</option>
            <option value="p">Paragraph</option>
          </select>
          <div class="sep"></div>
          <button type="button" onclick="fmt('en','bold')"><b>B</b></button>
          <button type="button" onclick="fmt('en','italic')"><i>I</i></button>
          <button type="button" onclick="fmt('en','underline')"><u>U</u></button>
          <div class="sep"></div>
          <button type="button" onclick="fmt('en','insertUnorderedList')">• List</button>
          <button type="button" onclick="fmt('en','insertOrderedList')">1. List</button>
          <div class="sep"></div>
          <button type="button" onclick="fmt('en','removeFormat')">✕ Clear</button>
        </div>
        <div class="editor-area" id="editor-en" contenteditable="true" dir="ltr"><%- exContent ? exContent.content_en : '' %></div>
        <input type="hidden" name="content_en" id="content_en">
      </div>

      <div style="display:flex; gap:1rem; align-items:center;">
        <button type="submit" class="btn btn-gold">שמור שינויים</button>
        <a href="/he/exhibitions" target="_blank" class="btn btn-dark btn-sm">תצוגה מקדימה ↗</a>
      </div>
    </form>

    <% if (locals.saved) { %>
    <div class="alert alert-success" style="margin-top:1.5rem;">✓ השינויים נשמרו בהצלחה</div>
    <% } %>
  </main>
</div>
<script>
  function focusEditor(lang) { document.getElementById('editor-'+lang).focus(); }
  function fmt(lang,cmd) { focusEditor(lang); document.execCommand(cmd,false,null); }
  function fmtBlock(lang,tag) { if(!tag)return; focusEditor(lang); document.execCommand('formatBlock',false,tag); }
  function syncContent() {
    document.getElementById('content_he').value = document.getElementById('editor-he').innerHTML;
    document.getElementById('content_en').value = document.getElementById('editor-en').innerHTML;
  }
  document.getElementById('exForm').addEventListener('submit', syncContent);
</script>
</body>
</html>
