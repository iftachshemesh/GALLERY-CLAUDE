<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { display: flex; align-items: center; justify-content: center; min-height: 100vh; background: #f5f5f5; }
    .login-box { background: white; padding: 2rem; border-radius: 8px; box-shadow: 0 2px 12px rgba(0,0,0,0.1); width: 100%; max-width: 360px; }
    h1 { text-align: center; margin-bottom: 1.5rem; font-size: 1.4rem; }
    input[type="password"] { width: 100%; padding: 0.6rem 0.8rem; margin-bottom: 1rem; border: 1px solid #ccc; border-radius: 4px; font-size: 1rem; box-sizing: border-box; }
    button { width: 100%; padding: 0.7rem; background: #333; color: white; border: none; border-radius: 4px; font-size: 1rem; cursor: pointer; }
    button:hover { background: #555; }
    .error { color: red; text-align: center; margin-bottom: 1rem; font-size: 0.9rem; }
  </style>
</head>
<body>
  <div class="login-box">
    <h1>כניסת מנהל</h1>
    <% if (error) { %>
      <p class="error">סיסמה שגויה. נסה שנית.</p>
    <% } %>
    <form method="POST" action="/admin/login">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="password" name="password" placeholder="סיסמה" autofocus required>
      <button type="submit">כניסה</button>
    </form>
  </div>
</body>
</html>
