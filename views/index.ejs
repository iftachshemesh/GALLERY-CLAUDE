<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= lang === 'he' ? 'rtl' : 'ltr' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= lang === 'he' ? "גלריית הציורים של ד\"ר יפתח שמש" : "Dr. Iftach Shemesh Art Gallery" %></title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    body { overflow: hidden; background: #0a0806; margin: 0; }
    @media (max-width: 600px) { body { overflow: auto; } }
    .site-nav .nav-links { display: none; }
    .site-nav { background: rgba(10,8,6,0.8); border-bottom: 1px solid var(--border); }
    .hero-bg { display: none !important; }
    .hero-overlay { display: none !important; }
    .hero {
      height: 100vh;
      background: #0a0806;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero-inner {
      position: relative;
      width: 100%;
      max-width: 1300px;
      height: 85vh;
      margin: 0 auto;
      padding: 0 2rem;
    }
    .hero-nav-left {
      position: absolute;
      left: 2rem;
      top: 50%;
      transform: translateY(-50%);
      display: flex;
      flex-direction: column;
      gap: 1.8rem;
      align-items: flex-start;
    }
    .hero-nav-left a {
      color: rgba(255,255,255,0.8);
      text-decoration: none;
      font-size: 0.95rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: color 0.2s;
      font-family: 'Heebo', sans-serif;
      white-space: nowrap;
      direction: rtl;
    }
    .hero-nav-left a:hover { color: var(--gold); }
    .hero-nav-left .lang-btn {
      padding: 0.3rem 0.8rem;
      border: 1px solid var(--gold);
      border-radius: 3px;
      color: var(--gold);
      font-size: 0.85rem;
      margin-top: 0.5rem;
      direction: ltr;
    }
    .hero-nav-left .lang-btn:hover { background: var(--gold); color: #0a0806; }
    .hero-painting-wrap {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
    }
    .hero-painting {
      height: 82vh;
      max-width: 50vw;
      object-fit: contain;
      display: block;
    }
    .hero-content {
      position: absolute;
      right: 2rem;
      top: 50%;
      transform: translateY(-50%);
      max-width: 260px;
      text-align: right;
      direction: rtl;
    }
    .hero-title {
      font-size: clamp(1.4rem, 2.5vw, 2.4rem);
      color: var(--white);
      line-height: 1.25;
      margin-bottom: 0.75rem;
      text-shadow: 0 2px 20px rgba(0,0,0,0.4);
    }
    .hero-subtitle {
      font-size: 0.95rem;
      color: var(--gold-light);
      letter-spacing: 0.1em;
      font-family: 'Cormorant Garamond', serif;
      font-style: italic;
    }
    @media (max-width: 800px) {
      body { overflow: auto; }
      .hero { height: auto; padding: 90px 1rem 2rem; }
      .hero-inner { height: auto; position: static; display: flex; flex-direction: column; align-items: center; gap: 2rem; padding: 0 1rem; }
      .hero-nav-left, .hero-painting-wrap, .hero-content { position: static; transform: none; }
      .hero-nav-left { flex-direction: row; flex-wrap: wrap; justify-content: center; gap: 1rem; }
      .hero-painting { height: auto; max-width: 85vw; max-height: 50vh; }
      .hero-content { text-align: center; max-width: 100%; }
    }
  </style>
</head>
<body dir="<%= lang === 'he' ? 'rtl' : 'ltr' %>">
<nav class="site-nav">
  <a href="/<%= lang %>" class="nav-brand"><%= lang === 'he' ? 'ד"ר יפתח שמש' : 'Dr. Iftach Shemesh' %></a>
  <div class="nav-links"></div>
</nav>
<div class="hero">
  <div class="hero-inner">

    <div class="hero-nav-left">
      <a href="/<%= lang %>/gallery"><%= lang === 'he' ? 'לגלריה' : 'View Gallery' %></a>
      <a href="/<%= lang %>/about"><%= lang === 'he' ? 'על אודות האמן' : 'About the Artist' %></a>
      <a href="/<%= lang %>/exhibitions"><%= lang === 'he' ? 'תערוכות וכתבות' : 'Exhibitions' %></a>
      <a href="/<%= lang %>/contact"><%= lang === 'he' ? 'צור קשר' : 'Contact' %></a>
      <a href="/<%= lang === 'he' ? 'en' : 'he' %>" class="lang-btn"><%= lang === 'he' ? 'EN' : 'עב' %></a>
    </div>

    <div class="hero-painting-wrap">
      <img class="hero-painting"
           src="https://res.cloudinary.com/dd6wpwsae/image/upload/e_background_removal,b_rgb:0a0806/hero_zijzst.png"
           alt="painting">
    </div>

    <div class="hero-content">
      <h1 class="hero-title"><%= lang === 'he' ? 'גלריית הציורים של ד"ר יפתח שמש' : 'Art Gallery of Dr. Iftach Shemesh' %></h1>
      <p class="hero-subtitle"><%= lang === 'he' ? 'אקריליק · פסטל · פחם' : 'Acrylic · Pastel · Charcoal' %></p>
    </div>

  </div>
</div>
<div class="legal-footer" style="position:fixed;bottom:0;left:0;right:0;z-index:50;">
  © <%= new Date().getFullYear() %> ד"ר יפתח שמש · כל הזכויות שמורות · All Rights Reserved
</div>
<button class="accessibility-btn" onclick="toggleAccess()" aria-label="נגישות">♿</button>
<div class="accessibility-panel" id="accessPanel">
  <h4><%= lang === 'he' ? 'נגישות' : 'Accessibility' %></h4>
  <div class="access-option">
    <span><%= lang === 'he' ? 'הגדל טקסט' : 'Larger text' %></span>
    <button onclick="changeFontSize(1)">A+</button>
    <button onclick="changeFontSize(-1)">A-</button>
  </div>
  <div class="access-option">
    <span><%= lang === 'he' ? 'ניגודיות' : 'Contrast' %></span>
    <button onclick="toggleContrast()">◑</button>
  </div>
</div>
<script>
  function toggleAccess() { document.getElementById('accessPanel').classList.toggle('open'); }
  let fontSize = 100;
  function changeFontSize(dir) { fontSize = Math.min(140, Math.max(80, fontSize + dir * 10)); document.body.style.fontSize = fontSize + '%'; }
  function toggleContrast() { document.body.classList.toggle('high-contrast'); }
</script>
</body>
</html>
